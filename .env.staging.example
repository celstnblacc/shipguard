# Copy to .env.staging and set real values before deployment.
# Keep .env.staging out of git.

# Container image tag deployed in staging.
SHIPGUARD_IMAGE_TAG=0.2.0

# Runtime environment.
PYTHONUNBUFFERED=1
SHIPGUARD_LOG_LEVEL=INFO

# Example secret placeholders (replace as needed for your environment).
# STAGING_API_TOKEN=<set-in-your-secret-store>
